# Copie a backend/.env y ajuste valores

# MongoDB (local u Atlas en producción)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=innovasoft_app

# API externa Innovasoft (sin barra final)
INNOVASOFT_API_BASE=https://pruebareactjs.test-class.com/Api

# Arranque
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# En Render con Dockerfile raíz usar SERVE_FRONTEND=true y build de frontend/dist
SERVE_FRONTEND=false
